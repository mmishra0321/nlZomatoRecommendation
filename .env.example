# App environment
APP_ENV=development
APP_PORT=8000

# LLM provider (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Dataset
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation
HF_DATASET_SPLIT=train

# Recommendation defaults
CANDIDATE_CAP=30
DEFAULT_TOP_N=5
REQUEST_TIMEOUT_SECONDS=25

# Backend API (Phase 6) — production
# Comma-separated browser origins, e.g. https://your-app.vercel.app
CORS_ORIGINS=
# Optional override (defaults to ManikaSaini/zomato-restaurant-recommendation)
DATASET_ID=
